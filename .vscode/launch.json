    "version": "0.2.0",
    "configurations": [

        {
            "name": "mg_chat",
            "request": "launch",
            "type": "dart",
            "args": ["--web-port", "8080", "--web-browser-flag=--disable-web-security"]
        },
        {
            "name": "mg_chat (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "mg_chat (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        {
            "name": "build_tool",
            "cwd": "build/flutter_vodozemac/build/build_tool",
            "request": "launch",
            "type": "dart"
        }
    ]
}